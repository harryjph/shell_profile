#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Validate input
if [ -z "$1" ]; then
  echo "Usage: $0 <server-name>"
  exit 1
fi

SERVER=$1
KUBE_DIR="$HOME/.kube"
LOCAL_KUBECONFIG="$KUBE_DIR/config"

# Create a temporary directory for working files
TEMP_DIR=$(mktemp -d)
REMOTE_KUBECONFIG="$TEMP_DIR/${SERVER}-raw.yaml"
MODIFIED_KUBECONFIG="$TEMP_DIR/${SERVER}-modified.json"

# Ensure cleanup of temp files on exit (even on errors)
trap "rm -rf '$TEMP_DIR'" EXIT

echo "⬇️  Fetching k3s config from ${SERVER}..."
# SSH into the server and fetch the config using sudo
ssh "$SERVER" "sudo cat /etc/rancher/k3s/k3s.yaml" > "$REMOTE_KUBECONFIG"

if [ ! -s "$REMOTE_KUBECONFIG" ]; then
  echo "❌ Failed to fetch kubeconfig or the file is empty."
  exit 1
fi

echo "⚙️  Modifying cluster, context, and user names to match '${SERVER}'..."
# Use kubectl to output raw json (retaining certs) and jq to update the fields
kubectl --kubeconfig "$REMOTE_KUBECONFIG" config view --raw -o json | \
jq --arg server "$SERVER" '
  .clusters[0].name = $server |
  .clusters[0].cluster.server = "https://\($server):6443" |
  .contexts[0].name = $server |
  .contexts[0].context.cluster = $server |
  .contexts[0].context.user = $server |
  .users[0].name = $server |
  ."current-context" = $server
' > "$MODIFIED_KUBECONFIG"

echo "🔗 Merging with local ~/.kube/config..."
mkdir -p "$KUBE_DIR"
touch "$LOCAL_KUBECONFIG"

# Create a backup of the existing config just in case
cp "$LOCAL_KUBECONFIG" "${LOCAL_KUBECONFIG}.bak.$(date +%F_%H-%M-%S)"

# Merge the configs using the KUBECONFIG environment variable 
KUBECONFIG="$LOCAL_KUBECONFIG:$MODIFIED_KUBECONFIG" \
kubectl config view --raw > "$TEMP_DIR/merged_config"

# Overwrite old config with the cleanly merged version and secure it
mv "$TEMP_DIR/merged_config" "$LOCAL_KUBECONFIG"
chmod 600 "$LOCAL_KUBECONFIG"

echo "✅ Success! Context '${SERVER}' has been merged into your kubeconfig."
echo "👉 You can now run: kubectl config use-context ${SERVER}"
